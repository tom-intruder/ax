#!/usr/bin/env bash

###########################################################################################################
# Header
#
AXIOM_PATH="$HOME/.axiom"
source "$AXIOM_PATH/interact/includes/vars.sh"
source "$AXIOM_PATH/interact/includes/functions.sh"

###########################################################################################################
# Defaults
#
uid=""
fleet=""
instance_arg=""
command=""
output_dir=""
timeout=300
sshconfig="$AXIOM_PATH/.sshconfig"
redis_start=false

###########################################################################################################
# Help
#
function usage() {
    echo -e "${BWhite}Usage:${Color_Off} axiom-queue [OPTIONS]"
    echo
    echo -e "${BWhite}Description:${Color_Off}"
    echo -e "  Dispatch a shell command to fleet instances via Redis queue."
    echo -e "  Instances pull tasks asynchronously via axiom-worker (no persistent SSH)."
    echo -e "  Requires conductor_ip set in axiom.json and axiom-worker running on instances."
    echo
    echo -e "${BWhite}Options:${Color_Off}"
    echo -e "  -f, --fleet <name>      Fleet prefix or instance file to target"
    echo -e "  -i, --instance <name>   Single instance to target"
    echo -e "  -c, --command <cmd>     Shell command to run on each instance (required)"
    echo -e "  -o, --output <dir>      Directory to collect per-instance output files"
    echo -e "  --uid <id>              Execution ID (default: timestamp)"
    echo -e "  --timeout <sec>         Per-instance result wait timeout (default: 300)"
    echo -e "  --sshconfig <file>      SSH config for output collection"
    echo -e "  --redis-start           Start Redis on conductor if not running"
    echo -e "  --help                  Show this menu"
    echo
    echo -e "${BWhite}Examples:${Color_Off}"
    echo -e "  ${BGreen}axiom-queue -f myfleet -c 'subfinder -d example.com' -o ./results${Color_Off}"
    echo -e "  ${BGreen}axiom-queue -i myinstance -c 'id' --timeout 60${Color_Off}"
}

###########################################################################################################
# Parse args
#
i=0
for arg in "$@"; do
    i=$((i+1))
    if [[ ! " ${pass[*]} " =~ " ${i} " ]]; then
        set=false
        if [[ "$arg" == "--fleet" ]] || [[ "$arg" == "-f" ]]; then
            n=$((i+1)); fleet="${!n}"; set=true; pass+=($i $n)
        elif [[ "$arg" == "--instance" ]] || [[ "$arg" == "-i" ]]; then
            n=$((i+1)); instance_arg="${!n}"; set=true; pass+=($i $n)
        elif [[ "$arg" == "--command" ]] || [[ "$arg" == "-c" ]]; then
            n=$((i+1)); command="${!n}"; set=true; pass+=($i $n)
        elif [[ "$arg" == "--output" ]] || [[ "$arg" == "-o" ]]; then
            n=$((i+1)); output_dir="${!n}"; set=true; pass+=($i $n)
        elif [[ "$arg" == "--uid" ]]; then
            n=$((i+1)); uid="${!n}"; set=true; pass+=($i $n)
        elif [[ "$arg" == "--timeout" ]]; then
            n=$((i+1)); timeout="${!n}"; set=true; pass+=($i $n)
        elif [[ "$arg" == "--sshconfig" ]]; then
            n=$((i+1)); sshconfig="${!n}"; set=true; pass+=($i $n)
        elif [[ "$arg" == "--redis-start" ]]; then
            redis_start=true; set=true; pass+=($i)
        elif [[ "$arg" == "--help" ]] || [[ "$arg" == "-h" ]]; then
            usage; exit 0
        fi
    fi
done

if [[ -z "$command" ]]; then
    echo -e "${BRed}Error: --command is required${Color_Off}"
    usage; exit 1
fi

[[ -z "$uid" ]] && uid="$(date +%s)"

###########################################################################################################
# Redis config — conductor_ip from axiom.json, falls back to localhost
#
conductor_ip="$(jq -r '.conductor_ip // empty' "$AXIOM_PATH/axiom.json")"
redis_port="$(jq -r '.redis_port // "6379"' "$AXIOM_PATH/axiom.json")"
[[ -z "$conductor_ip" || "$conductor_ip" == "null" ]] && conductor_ip="127.0.0.1"

###########################################################################################################
# Redis helpers — use Docker exec so conductor doesn't need redis-cli installed
#
redis_cmd() {
    docker exec axiom-redis redis-cli --no-auth-warning "$@"
}

ensure_redis() {
    if ! redis_cmd ping >/dev/null 2>&1; then
        if [[ "$redis_start" != "true" ]]; then
            echo -e "${BRed}Error: Redis is not running. Pass --redis-start to launch it automatically.${Color_Off}"
            exit 1
        fi
        echo -e "${BYellow}Starting Redis on ${conductor_ip}:${redis_port}...${Color_Off}"
        docker rm -f axiom-redis >/dev/null 2>&1 || true
        docker run -d --name axiom-redis --restart unless-stopped \
            -p "${conductor_ip}:${redis_port}:6379" \
            redis:7-alpine redis-server --save "" --loglevel warning >/dev/null
        local tries=0
        while ! redis_cmd ping >/dev/null 2>&1; do
            sleep 1
            tries=$((tries+1))
            if [[ $tries -ge 15 ]]; then
                echo -e "${BRed}Failed to start Redis after 15s${Color_Off}"
                exit 1
            fi
        done
        echo -e "${BGreen}Redis started on ${conductor_ip}:${redis_port}${Color_Off}"
    fi
}

ensure_redis

###########################################################################################################
# Resolve instance list
#
instances=()
if [[ -n "${fleet:-}" ]]; then
    if [[ -f "$fleet" ]]; then
        while IFS= read -r line; do [[ -n "$line" ]] && instances+=("$line"); done < "$fleet"
    else
        while IFS= read -r line; do [[ -n "$line" ]] && instances+=("$line"); done \
            <<< "$(query_instances_cache "${fleet}*" | tr ' ' '\n')"
    fi
elif [[ -n "${instance_arg:-}" ]]; then
    instances+=("$instance_arg")
elif [[ -f "$AXIOM_PATH/selected.conf" ]]; then
    while IFS= read -r line; do [[ -n "$line" ]] && instances+=("$line"); done < "$AXIOM_PATH/selected.conf"
fi

if [[ ${#instances[@]} -eq 0 ]]; then
    echo -e "${BRed}Error: no instances resolved${Color_Off}"
    exit 1
fi

[[ -n "$output_dir" ]] && mkdir -p "$output_dir"

total=${#instances[@]}
echo -e "${BWhite}Dispatching to ${BGreen}$total${BWhite} instances via Redis queue (uid=${BGreen}$uid${BWhite})${Color_Off}"

###########################################################################################################
# Push tasks to per-instance queues
#
for instance in "${instances[@]}"; do
    task="$(jq -n --arg uid "$uid" --arg cmd "$command" --arg inst "$instance" \
        '{uid: $uid, command: $cmd, instance: $inst}')"
    redis_cmd LPUSH "axiom:task:$instance" "$task" >/dev/null
done
echo -e "${BWhite}Tasks dispatched. Waiting for results (timeout=${timeout}s each)...${Color_Off}"

###########################################################################################################
# Wait for results in parallel — one background job per instance
# Each job BLPOPs its result key, then SCPs the output file (single short SSH per instance)
#
for instance in "${instances[@]}"; do
    (
        result_key="axiom:result:${uid}:${instance}"
        # --raw gives us two plain lines: the key name, then the JSON value
        raw="$(docker exec axiom-redis redis-cli --no-auth-warning --raw \
            BLPOP "$result_key" "$timeout" 2>/dev/null)"

        if [[ -z "$raw" ]]; then
            echo -e "${BRed}[$instance]${Color_Off} timeout after ${timeout}s"
            exit 1
        fi

        result_json="$(echo "$raw" | tail -n 1)"
        exit_code="$(echo "$result_json" | jq -r '.exit_code // "?"' 2>/dev/null)"
        output_inline="$(echo "$result_json" | jq -r '.output // empty' 2>/dev/null)"
        echo -e "${BGreen}[$instance]${Color_Off} done (exit=$exit_code)"

        if [[ -n "$output_dir" ]]; then
            mkdir -p "$output_dir"
            if [[ -n "$output_inline" ]]; then
                # Output was small enough to be embedded in the result — no SSH needed
                printf '%s' "$output_inline" > "${output_dir}/${instance}"
                echo -e "${BGreen}[$instance]${Color_Off} output -> ${output_dir}/${instance} (via Redis)"
            else
                # Output exceeded inline limit; retrieve via a single SCP
                remote_path="/tmp/axiom-queue/${uid}/output"
                if axiom-scp "${instance}:${remote_path}" "${output_dir}/${instance}" \
                        --cache -F="$sshconfig" >/dev/null 2>&1; then
                    echo -e "${BGreen}[$instance]${Color_Off} output -> ${output_dir}/${instance} (via SCP)"
                else
                    echo -e "${BYellow}[$instance]${Color_Off} output copy failed (instance may have terminated)"
                fi
            fi
        fi
    ) &
done

wait
echo -e "${BGreen}Queue execution complete (uid=$uid)${Color_Off}"
